# --- ghostty settings

adjust-cell-height = 50%
clipboard-read = allow
clipboard-write = allow
command =  /opt/homebrew/bin/fish -l -c "$HOME/dotfiles/scripts/tmux-home.sh"

# --- fonts

# font-family = Victor Mono
# font-family = BlexMono Nerd Font Mono
# font-family = Jetbrains Mono NFM
# font-family = M+1CodeLat50 Nerd Font Mono
# font-family = NotoSansM Nerd Font Mono
font-family = SF Mono Terminal
font-size = 13
font-thicken = true
font-thicken-strength = 100

# --- mac settings

# official, blueprint, chalkboard, microchip, glass, holographic, paper, retro, xray
macos-icon = custom
macos-custom-icon = ~/.config/ghostty/Ghostty.icns
macos-non-native-fullscreen = true
macos-titlebar-style = hidden
resize-overlay = never

# --- theme

# theme = dark:nightfox,light:dayfox
theme = dark:Github Dark Dimmed,light:Github Light Default
# theme = dark:Catppuccin Macchiato,light:Catppuccin Latte
mouse-hide-while-typing = true
window-padding-balance = true
window-padding-x = 15
window-padding-y = 10
# background-blur = macos-glass-regular

# --- quick terminal
quick-terminal-position = bottom
quick-terminal-size = 45%

# --- keybinds

# new tmux window
keybind = super+n=text:ç
keybind = super+r=text:÷

# tmux next/prev window
keybind = super+shift+bracket_left=text:˙
keybind = super+shift+bracket_right=text:¬

# tmux close window
keybind = super+w=text:≈

# tmux kill session
keybind = super+shift+x=text:˛

# tmux zoom
keybind = super+z=text:⌟

# newlines in claude/codex
keybind = shift+enter=text:\x1b\r

# swap tmux panes
keybind = ctrl+super+h=text:Ë
keybind = ctrl+super+l=text:Ï

# resize tmux panes
keybind = super+alt+left=text:Ó
keybind = super+alt+right=text:Ô
keybind = super+alt+h=text:Ó
keybind = super+alt+l=text:Ô

# even out pane layout (sends ctrl+f then =)
keybind = super+alt+equal=text:\x06=

# pass these to tmux for pane sizing
keybind = alt+up=unbind
keybind = alt+down=unbind

# quick terminal
keybind = global:alt+\=toggle_quick_terminal
